# --- Directorios de sistema y control de versiones ---
.git
.gitignore
.dockerignore
.idea
.vscode
__pycache__
*/__pycache__
*.pyc
*.pyo
*.pyd

# --- Archivos de configuración de entorno y secretos ---
.env
.env.*
*.env

# --- Documentación y archivos informativos (No necesarios en producción) ---
*.md
documentacion_tecnica.md
documentacion_tecnica.txt
pasos.md

# --- Archivos de Base de Datos y Backups (¡CRÍTICO!) ---
# Ignoramos los dumps para no inflar la imagen de Docker.
# Estos se deben montar como volúmenes en el docker-compose, no copiarse dentro.
*.sql
*.dump
backup_dropbox.sql
entregable_IT.sql

# --- Archivos de infraestructura (No se necesitan DENTRO del contenedor) ---
docker-compose.yaml
service.yaml
Dockerfile
